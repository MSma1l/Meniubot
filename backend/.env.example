TELEGRAM_BOT_TOKEN=your_token_here
FLASK_PORT=5000
# Obligatoriu. Aplicația nu pornește fără el și respinge explicit valorile
# `dev-secret-key` și `your_secret_key`. Generează-l cu:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# Obligatoriu. Secret partajat între backend și procesul bot, trimis în headerul
# `X-Internal-Token`. Backend-ul și botul refuză să pornească fără el. Generează-l cu:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_TOKEN=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
OFFICE_ADDRESS=str. Exemplu 123, Chișinău
WEBAPP_URL=https://yourdomain.com/webapp
